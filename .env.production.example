# ===== Production .env (copy to .env on the prod server) =====
# Database — points to the SAME Postgres that dev uses, but via the
# private network IP so traffic stays inside your VPC / LAN.
DB_HOST=10.98.68.254
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD="LEpooh2901#"
DB_NAME=apartment_db
DB_SSL=false

# JWT — REPLACE with a long random string before going live
JWT_SECRET=please_generate_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# Backend
PORT=5000
NODE_ENV=production

# Frontend
# If front and back are served from the same domain via nginx, use /api .
# If you serve frontend separately, point this at the backend URL.
REACT_APP_API_URL=/api
